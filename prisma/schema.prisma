generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkspacePlan {
  STARTER
  GROWTH
  PRO
}

enum UserRole {
  ADMIN
  AGENT
  REVIEWER
  OPS
  COMPANY_OWNER
  COMPANY_ADMIN
  ORGANISATION_ACCESS_ADMIN
  PRINCIPAL_REGISTERED_MIGRATION_AGENT
  SENIOR_MIGRATION_AGENT
  MIGRATION_AGENT
  CASE_MANAGER
  ADMIN_ASSISTANT
  CLIENT_REVIEW_COORDINATOR
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum UserVisibilityScope {
  ASSIGNED_ONLY
  TEAM_OVERSIGHT
  FIRM_WIDE
}

enum MatterStatus {
  IN_PROGRESS
  AWAITING_DOCS
  READY_FOR_REVIEW
  DRAFT
}

enum MatterStage {
  INTAKE
  EVIDENCE
  FIELD_REVIEW
  VALIDATION
  SUBMISSION_PREP
}

enum ExtractionStatus {
  QUEUED
  EXTRACTED
  NEEDS_REVIEW
}

enum ReviewStatus {
  PENDING
  VERIFIED
  FLAGGED
}

enum FieldStatus {
  HIGH_CONFIDENCE
  SUPPORTED
  NEEDS_REVIEW
  CONFLICTING
  MISSING
  VERIFIED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ResolutionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImpactStatus {
  NEW
  REVIEWING
  ACTIONED
  DISMISSED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IntakeRequestStatus {
  DRAFT
  SENT
  VIEWED
  SUBMITTED
  REVIEWED
}

enum DocumentRequestStatus {
  DRAFT
  SENT
  VIEWED
  COMPLETED
  OVERDUE
}

enum DocumentRequestItemStatus {
  MISSING
  REQUESTED
  RECEIVED
  REVIEWED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum GeneratedDocumentType {
  COVER_LETTER
  STATUTORY_DECLARATION_TEMPLATE
  DOCUMENT_REQUEST_CHECKLIST
  SKILLS_ASSESSMENT_CHECKLIST
  SPONSORSHIP_CHECKLIST
  CHARACTER_REFERENCE_TEMPLATE
  GENUINE_STUDENT_STATEMENT_OUTLINE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
  OVERDUE
}

enum InvoiceAssetKind {
  LOGO
  SIGNATURE
  TEMPLATE
  ATTACHMENT
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
}

enum TemplateValueType {
  TEXT
  DATE
  NUMBER
  BOOLEAN
  CURRENCY
  SELECT
  MULTI_SELECT
}

enum DraftStatus {
  DRAFTING
  READY_FOR_AGENT_REVIEW
  AGENT_REVIEWED
  READY_FOR_CLIENT_REVIEW
  SENT_TO_CLIENT
  CLIENT_CONFIRMED
  RETURNED_TO_AGENT
  NEEDS_WORK
}

enum DraftFieldStatus {
  HIGH_CONFIDENCE
  SUPPORTED
  NEEDS_REVIEW
  CONFLICTING
  MISSING
  VERIFIED
}

enum ReviewRequestStatus {
  REVIEW_REQUESTED
  SENT_TO_CLIENT
  VIEWED_BY_CLIENT
  SIGNED_CONFIRMED
  RETURNED_TO_AGENT
  REQUIRES_FOLLOW_UP
}

model Workspace {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  plan                  WorkspacePlan
  legalName             String?
  businessType          String?
  registrationNumber    String?
  contactEmail          String?
  contactPhone          String?
  website               String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  postalCode            String?
  country               String?
  timezone              String                 @default("Australia/Sydney")
  logoUrl               String?
  brandColor            String?
  createdAt             DateTime               @default(now())
  users                 User[]
  clients               Client[]
  matters               Matter[]
  documents             Document[]
  tasks                 Task[]
  aiThreads             AiChatThread[]
  auditEvents           AuditEvent[]
  visaSubclassTemplates VisaSubclassTemplate[]
  visaKnowledgeRecords  VisaKnowledgeRecord[]
  officialSources       OfficialSource[]
  pathwayAnalyses       PathwayAnalysis[]
  intakeRequests        ClientIntakeRequest[]
  documentRequests      DocumentRequest[]
  appointments          Appointment[]
  generatedDocuments    GeneratedDocument[]
  portalAccessTokens    ClientPortalAccessToken[]
  timelineEvents        MatterTimelineEvent[]
  knowledgeEmbeddings   KnowledgeEmbedding[]
  invoiceBranding       InvoiceBranding?
  invoiceTemplates      InvoiceTemplate[]
  invoiceServices       InvoiceService[]
  invoices              Invoice[]
  invoiceAssets         InvoiceAsset[]
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  hashedPassword    String?
  role              UserRole
  status            UserStatus          @default(ACTIVE)
  jobTitle          String?
  notes             String?
  permissionsJson   Json?
  visibilityScope   UserVisibilityScope @default(ASSIGNED_ONLY)
  invitedAt         DateTime?
  inviteTokenHash   String?             @unique
  inviteExpiresAt   DateTime?
  inviteAcceptedAt  DateTime?
  lastActiveAt      DateTime?
  deactivatedAt     DateTime?
  workspaceId       String
  workspace         Workspace           @relation(fields: [workspaceId], references: [id])
  supervisorId      String?
  supervisor        User?               @relation("UserSupervisor", fields: [supervisorId], references: [id])
  supervisedUsers   User[]              @relation("UserSupervisor")
  mattersAssigned   Matter[]            @relation("MatterAssignee")
  clientsAssigned   Client[]            @relation("ClientAssignee")
  uploadedDocuments Document[]          @relation("DocumentUploader")
  tasksAssigned     Task[]              @relation("TaskAssignee")
  createdThreads    AiChatThread[]      @relation("ThreadCreator")
  auditEvents       AuditEvent[]
  pathwayAnalyses   PathwayAnalysis[]
  intakeRequests    ClientIntakeRequest[] @relation("IntakeRequestCreator")
  documentRequests  DocumentRequest[]     @relation("DocumentRequestCreator")
  appointments      Appointment[]         @relation("AppointmentAssignee")
  generatedDocuments GeneratedDocument[]
  timelineEvents    MatterTimelineEvent[] @relation("TimelineActor")
  invoicesCreated   Invoice[]             @relation("InvoiceCreator")
  invoiceTemplatesCreated InvoiceTemplate[] @relation("InvoiceTemplateCreator")

  @@index([workspaceId, status])
  @@index([inviteExpiresAt])
}

model Client {
  id               String            @id @default(cuid())
  clientReference  String?           @unique
  workspaceId      String
  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  firstName        String
  lastName         String
  dob              DateTime
  nationality      String
  email            String
  phone            String
  notes            String?
  assignedToUserId String?
  assignedToUser   User?             @relation("ClientAssignee", fields: [assignedToUserId], references: [id])
  createdAt        DateTime          @default(now())
  currentVisaStatus String?
  currentVisaExpiry DateTime?
  archivedAt       DateTime?
  matters          Matter[]
  documents        Document[]
  pathwayAnalyses  PathwayAnalysis[]
  intakeRequests   ClientIntakeRequest[]
  documentRequests DocumentRequest[]
  appointments     Appointment[]
  portalAccessTokens ClientPortalAccessToken[]
  invoices         Invoice[]
}

model Matter {
  id                  String                   @id @default(cuid())
  matterReference     String?                  @unique
  workspaceId         String
  workspace           Workspace                @relation(fields: [workspaceId], references: [id])
  clientId            String
  client              Client                   @relation(fields: [clientId], references: [id])
  title               String
  visaSubclass        String
  visaStream          String
  status              MatterStatus
  stage               MatterStage
  currentVisaStatus   String?
  currentVisaExpiry   DateTime?
  applicationStatus   String?
  lodgementDate       DateTime?
  expectedNextMilestone String?
  criticalDeadline    DateTime?
  archivedAt          DateTime?
  lodgementTargetDate DateTime?
  assignedToUserId    String
  assignedToUser      User                     @relation("MatterAssignee", fields: [assignedToUserId], references: [id])
  readinessScore      Int
  lastReviewedAt      DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  documents           Document[]
  extractedFields     ExtractedField[]
  validationIssues    ValidationIssue[]
  checklistItems      ChecklistItem[]
  impacts             MatterImpact[]
  tasks               Task[]
  aiThreads           AiChatThread[]
  applicationDrafts   MatterApplicationDraft[]
  reviewRequests      MatterReviewRequest[]
  pathwayAnalyses     PathwayAnalysis[]
  intakeRequests      ClientIntakeRequest[]
  documentRequests    DocumentRequest[]
  appointments        Appointment[]
  generatedDocuments  GeneratedDocument[]
  portalAccessTokens  ClientPortalAccessToken[]
  timelineEvents      MatterTimelineEvent[]
  invoices            Invoice[]
}

model PathwayAnalysis {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId  String
  createdByUser    User            @relation(fields: [createdByUserId], references: [id])
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  matterId         String?
  matter           Matter?         @relation(fields: [matterId], references: [id], onDelete: SetNull)
  title            String
  profileJson      Json
  summary          String
  assumptionsJson  Json
  blockersJson     Json
  evidenceGapsJson Json
  reviewNotes      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  options          PathwayOption[]

  @@index([workspaceId, createdAt])
  @@index([matterId])
}

model PathwayOption {
  id              String          @id @default(cuid())
  analysisId      String
  analysis        PathwayAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  rank            Int
  pathwayType     String
  title           String
  relevance       String
  confidence      Float
  conditionsJson  Json
  missingJson     Json
  risksJson       Json
  nextActionsJson Json
  createdAt       DateTime        @default(now())
}

model Document {
  id                 String                         @id @default(cuid())
  workspaceId        String
  workspace          Workspace                      @relation(fields: [workspaceId], references: [id])
  clientId           String
  client             Client                         @relation(fields: [clientId], references: [id])
  matterId           String
  matter             Matter                         @relation(fields: [matterId], references: [id])
  fileName           String
  storageKey         String
  mimeType           String
  fileSize           Int?
  contentHash        String?
  category           String
  subcategory        String?
  uploadedByUserId   String
  uploadedByUser     User                           @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  extractionStatus   ExtractionStatus
  reviewStatus       ReviewStatus
  createdAt          DateTime                       @default(now())
  extractedFields    ExtractedField[]
  draftEvidenceLinks MatterDraftFieldEvidenceLink[]
  extractionResults  DocumentExtractionResult[]
  storageObject      DocumentStorageObject?
  checklistItems     ChecklistItem[]
}

model DocumentStorageObject {
  id         String   @id @default(cuid())
  documentId String   @unique
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider   String
  storageKey String
  data       Bytes?
  createdAt  DateTime @default(now())
}

model ExtractedField {
  id            String      @id @default(cuid())
  matterId      String
  matter        Matter      @relation(fields: [matterId], references: [id])
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id])
  fieldKey      String
  fieldLabel    String
  fieldValue    String
  confidence    Float
  sourceSnippet String
  sourcePageRef String
  status        FieldStatus
  needsReview   Boolean
  createdAt     DateTime    @default(now())
}

model ValidationIssue {
  id               String           @id @default(cuid())
  matterId         String
  matter           Matter           @relation(fields: [matterId], references: [id])
  severity         IssueSeverity
  type             String
  title            String
  description      String
  relatedFieldKey  String?
  resolutionStatus ResolutionStatus
  createdAt        DateTime         @default(now())
}

model ChecklistItem {
  id       String  @id @default(cuid())
  matterId String
  matter   Matter  @relation(fields: [matterId], references: [id])
  documentId String?
  document  Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  itemKey   String?
  category String
  label    String
  description String?
  status   String
  required Boolean
  notes    String?
  dueDate  DateTime?
  requestedAt DateTime?
  reviewedAt DateTime?
  requestItems DocumentRequestItem[]
}

model VisaSubclassTemplate {
  id             String                      @id @default(cuid())
  workspaceId    String?
  workspace      Workspace?                  @relation(fields: [workspaceId], references: [id])
  subclassCode   String
  stream         String?
  name           String
  description    String
  version        String
  active         Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  sections       VisaTemplateSection[]
  fields         VisaTemplateField[]
  requirements   VisaTemplateRequirement[]
  checklistItems VisaTemplateChecklistItem[]
  drafts         MatterApplicationDraft[]

  @@unique([workspaceId, subclassCode, stream, version])
  @@index([subclassCode, stream, active])
}

model VisaKnowledgeRecord {
  id                  String     @id @default(cuid())
  workspaceId         String?
  workspace           Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subclassCode        String?
  stream              String?
  title               String
  summary             String
  keyRequirementsJson Json
  evidenceJson        Json
  sourceUrl           String
  sourceType          String
  contentHash         String
  lastRefreshedAt     DateTime   @default(now())
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([sourceUrl, contentHash])
  @@index([workspaceId])
  @@index([subclassCode, stream])
  @@index([lastRefreshedAt])
}

model VisaTemplateSection {
  id          String               @id @default(cuid())
  templateId  String
  template    VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key         String
  title       String
  description String?
  sortOrder   Int
  fields      VisaTemplateField[]

  @@unique([templateId, key])
}

model VisaTemplateField {
  id                          String               @id @default(cuid())
  templateId                  String
  template                    VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionId                   String
  section                     VisaTemplateSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  fieldKey                    String
  label                       String
  helpText                    String?
  valueType                   TemplateValueType
  required                    Boolean              @default(false)
  supportedDocumentCategories String[]
  validationRules             Json?
  sortOrder                   Int
  draftFields                 MatterDraftField[]

  @@unique([templateId, fieldKey])
}

model VisaTemplateRequirement {
  id           String               @id @default(cuid())
  templateId   String
  template     VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category     String
  label        String
  description  String
  required     Boolean              @default(true)
  ruleKey      String
  metadataJson Json?

  @@unique([templateId, ruleKey])
}

model VisaTemplateChecklistItem {
  id           String               @id @default(cuid())
  templateId   String
  template     VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category     String
  label        String
  required     Boolean              @default(true)
  sortOrder    Int
  metadataJson Json?
}

model MatterApplicationDraft {
  id             String                @id @default(cuid())
  matterId       String
  matter         Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  templateId     String
  template       VisaSubclassTemplate  @relation(fields: [templateId], references: [id])
  status         DraftStatus           @default(DRAFTING)
  readinessScore Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  fields         MatterDraftField[]
  reviewRequests MatterReviewRequest[]

  @@unique([matterId, templateId])
}

model MatterDraftField {
  id              String                         @id @default(cuid())
  draftId         String
  draft           MatterApplicationDraft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  templateFieldId String
  templateField   VisaTemplateField              @relation(fields: [templateFieldId], references: [id])
  value           String?
  confidence      Float?
  sourceSnippet   String?
  sourcePageRef   String?
  status          DraftFieldStatus               @default(MISSING)
  reviewedAt      DateTime?
  verifiedAt      DateTime?
  manualOverride  String?
  notes           String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  evidenceLinks   MatterDraftFieldEvidenceLink[]

  @@unique([draftId, templateFieldId])
}

model MatterDraftFieldEvidenceLink {
  id            String           @id @default(cuid())
  draftFieldId  String
  draftField    MatterDraftField @relation(fields: [draftFieldId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sourceSnippet String?
  sourcePageRef String?
  confidence    Float?
  createdAt     DateTime         @default(now())
}

model DocumentExtractionResult {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider      String
  model         String?
  extractedJson Json
  createdAt     DateTime @default(now())
}

model MatterReviewRequest {
  id             String                 @id @default(cuid())
  matterId       String
  matter         Matter                 @relation(fields: [matterId], references: [id], onDelete: Cascade)
  draftId        String
  draft          MatterApplicationDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  status         ReviewRequestStatus    @default(REVIEW_REQUESTED)
  recipientEmail String?
  recipientName  String?
  message        String?
  sentAt         DateTime?
  viewedAt       DateTime?
  confirmedAt    DateTime?
  returnedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model ClientIntakeRequest {
  id              String              @id @default(cuid())
  workspaceId     String
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  matterId        String?
  matter          Matter?             @relation(fields: [matterId], references: [id], onDelete: SetNull)
  createdByUserId String
  createdByUser   User                @relation("IntakeRequestCreator", fields: [createdByUserId], references: [id])
  title           String
  recipientName   String?
  recipientEmail  String?
  message         String?
  status          IntakeRequestStatus @default(DRAFT)
  tokenHash       String              @unique
  expiresAt       DateTime
  viewedAt        DateTime?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  questionnaireJson Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ClientPortalAccessToken {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matterId        String?
  matter          Matter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
  tokenHash       String   @unique
  label           String
  expiresAt       DateTime
  lastViewedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DocumentRequest {
  id              String                @id @default(cuid())
  workspaceId     String
  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  matterId        String
  matter          Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdByUser   User                  @relation("DocumentRequestCreator", fields: [createdByUserId], references: [id])
  recipientName   String?
  recipientEmail  String?
  message         String?
  dueDate         DateTime?
  status          DocumentRequestStatus @default(DRAFT)
  tokenHash       String                @unique
  expiresAt       DateTime
  viewedAt        DateTime?
  completedAt     DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           DocumentRequestItem[]
}

model DocumentRequestItem {
  id             String                    @id @default(cuid())
  requestId      String
  request        DocumentRequest           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem  ChecklistItem             @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  status         DocumentRequestItemStatus @default(MISSING)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([requestId, checklistItemId])
}

model Appointment {
  id               String            @id @default(cuid())
  workspaceId      String
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId         String?
  client           Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  matterId         String?
  matter           Matter?           @relation(fields: [matterId], references: [id], onDelete: SetNull)
  assignedToUserId String?
  assignedToUser   User?             @relation("AppointmentAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  requestedByName  String?
  requestedByEmail String?
  status           AppointmentStatus @default(REQUESTED)
  meetingType      String
  startsAt         DateTime
  notes            String?
  tokenHash        String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model GeneratedDocument {
  id              String                @id @default(cuid())
  workspaceId     String
  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  matterId        String
  matter          Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdByUser   User                  @relation(fields: [createdByUserId], references: [id])
  type            GeneratedDocumentType
  title           String
  content         String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model MatterTimelineEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  matterId    String
  matter      Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorUser   User?     @relation("TimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   String
  title       String
  description String?
  metadataJson Json?
  createdAt   DateTime  @default(now())

  @@index([matterId, createdAt])
}

model OfficialUpdate {
  id               String          @id @default(cuid())
  officialSourceId String?
  officialSource   OfficialSource? @relation(fields: [officialSourceId], references: [id])
  source           String
  sourceUrl        String
  title            String
  summary          String
  updateType       String
  effectiveDate    DateTime?
  publishedAt      DateTime
  rawContentHash   String
  sourceMetadata   Json?
  ingestedAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  impacts          MatterImpact[]

  @@unique([sourceUrl, rawContentHash])
  @@index([publishedAt])
  @@index([updateType])
}

model OfficialSource {
  id            String           @id @default(cuid())
  workspaceId   String?
  workspace     Workspace?       @relation(fields: [workspaceId], references: [id])
  name          String
  sourceType    String
  url           String
  active        Boolean          @default(true)
  metadataJson  Json?
  lastFetchedAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  updates       OfficialUpdate[]

  @@unique([url])
  @@index([active, sourceType])
}

model MatterImpact {
  id               String         @id @default(cuid())
  officialUpdateId String
  officialUpdate   OfficialUpdate @relation(fields: [officialUpdateId], references: [id])
  matterId         String
  matter           Matter         @relation(fields: [matterId], references: [id])
  impactLevel      ImpactLevel
  reason           String
  actionRequired   String?
  status           ImpactStatus
  createdAt        DateTime       @default(now())

  @@unique([officialUpdateId, matterId])
}

model Task {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id])
  matterId         String
  matter           Matter       @relation(fields: [matterId], references: [id])
  assignedToUserId String
  assignedToUser   User         @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  title            String
  description      String
  dueDate          DateTime
  status           TaskStatus
  priority         TaskPriority
}

model AiChatThread {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  matterId        String?
  matter          Matter?         @relation(fields: [matterId], references: [id])
  title           String
  createdByUserId String
  createdByUser   User            @relation("ThreadCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime        @default(now())
  messages        AiChatMessage[]
}

model AiChatMessage {
  id            String       @id @default(cuid())
  threadId      String
  thread        AiChatThread @relation(fields: [threadId], references: [id])
  role          ChatRole
  content       String
  citationsJson Json?
  createdAt     DateTime     @default(now())
}

model AuditEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  entityType   String
  entityId     String
  action       String
  metadataJson Json?
  createdAt    DateTime  @default(now())
}

model KnowledgeEmbedding {
  id            String    @id @default(cuid())
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType    String
  entityId      String
  content       String
  embeddingJson Json?
  sourceUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId, entityType])
  @@unique([entityType, entityId])
}

model InvoiceBranding {
  id                     String        @id @default(cuid())
  workspaceId            String        @unique
  workspace              Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  businessName           String
  legalName              String?
  contactEmail           String?
  contactPhone           String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  postalCode             String?
  country                String?
  website                String?
  abnAcn                 String?
  paymentInstructions    String?
  bankDetails            String?
  defaultCurrency        String        @default("AUD")
  defaultGstRateBps      Int           @default(1000)
  defaultDueDays         Int           @default(7)
  logoAssetId            String?        @unique
  signatureAssetId       String?        @unique
  logoAsset              InvoiceAsset? @relation("InvoiceBrandingLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
  signatureAsset         InvoiceAsset? @relation("InvoiceBrandingSignature", fields: [signatureAssetId], references: [id], onDelete: SetNull)
  invoices               Invoice[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model InvoiceTemplate {
  id                 String         @id @default(cuid())
  workspaceId        String
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  notes              String?
  extractedText      String?
  detectedFieldsJson Json?
  extractionWarnings Json?
  assetId            String?         @unique
  asset              InvoiceAsset?  @relation("InvoiceTemplateAsset", fields: [assetId], references: [id], onDelete: SetNull)
  createdByUserId    String?
  createdByUser      User?          @relation("InvoiceTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  invoices           Invoice[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([workspaceId, createdAt])
}

model InvoiceService {
  id                  String      @id @default(cuid())
  workspaceId         String
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  serviceName         String
  description         String?
  defaultPriceCents   Int
  currency            String      @default("AUD")
  gstRateBps          Int         @default(1000)
  isTaxInclusive      Boolean     @default(false)
  active              Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([workspaceId, active])
}

model Invoice {
  id                    String         @id @default(cuid())
  workspaceId           String
  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId              String?
  client                Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  matterId              String?
  matter                Matter?        @relation(fields: [matterId], references: [id], onDelete: SetNull)
  createdByUserId       String
  createdByUser         User           @relation("InvoiceCreator", fields: [createdByUserId], references: [id])
  templateId            String?
  template              InvoiceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  brandingId            String?
  branding              InvoiceBranding? @relation(fields: [brandingId], references: [id], onDelete: SetNull)
  clientName            String
  clientEmail           String?
  clientAddress         String?
  invoiceNumber         String
  issueDate             DateTime
  dueDate               DateTime
  currency              String        @default("AUD")
  subtotalCents         Int           @default(0)
  gstCents              Int           @default(0)
  discountCents         Int           @default(0)
  totalCents            Int           @default(0)
  lineItemsJson         Json
  notes                 String?
  paymentInstructions   String?
  generatedContent      String?
  aiReasoningJson       Json?
  reviewRequired        Boolean       @default(true)
  status                InvoiceStatus @default(DRAFT)
  sentAt                DateTime?
  paidAt                DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  assets                InvoiceAsset[] @relation("InvoiceAttachment")

  @@unique([workspaceId, invoiceNumber])
  @@index([workspaceId, status, issueDate])
}

model InvoiceAsset {
  id                   String           @id @default(cuid())
  workspaceId          String
  workspace            Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandingLogoFor      InvoiceBranding? @relation("InvoiceBrandingLogo")
  brandingSignatureFor InvoiceBranding? @relation("InvoiceBrandingSignature")
  templateFor          InvoiceTemplate? @relation("InvoiceTemplateAsset")
  invoiceId            String?
  invoice              Invoice?         @relation("InvoiceAttachment", fields: [invoiceId], references: [id], onDelete: SetNull)
  kind                 InvoiceAssetKind
  fileName             String
  mimeType             String
  storageKey           String
  contentHash          String?
  fileSize             Int?
  extractedText        String?
  detectedFieldsJson   Json?
  data                 Bytes?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([workspaceId, kind])
}
