generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan { STARTER GROWTH PRO }
enum UserRole { ADMIN AGENT REVIEWER OPS }
enum MatterStatus { IN_PROGRESS AWAITING_DOCS READY_FOR_REVIEW DRAFT }
enum MatterStage { INTAKE EVIDENCE FIELD_REVIEW VALIDATION SUBMISSION_PREP }
enum ExtractionStatus { QUEUED EXTRACTED NEEDS_REVIEW }
enum ReviewStatus { PENDING VERIFIED FLAGGED }
enum FieldStatus { HIGH_CONFIDENCE SUPPORTED NEEDS_REVIEW CONFLICTING MISSING VERIFIED }
enum IssueSeverity { LOW MEDIUM HIGH CRITICAL }
enum ResolutionStatus { OPEN IN_PROGRESS RESOLVED DISMISSED }
enum ImpactLevel { LOW MEDIUM HIGH }
enum ImpactStatus { NEW REVIEWING ACTIONED DISMISSED }
enum TaskStatus { OPEN IN_PROGRESS DONE }
enum TaskPriority { LOW MEDIUM HIGH URGENT }
enum ChatRole { SYSTEM USER ASSISTANT }

model Workspace {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  plan       WorkspacePlan
  createdAt  DateTime @default(now())
  users      User[]
  clients    Client[]
  matters    Matter[]
  documents  Document[]
  tasks      Task[]
  aiThreads  AiChatThread[]
  auditEvents AuditEvent[]
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  role        UserRole
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  mattersAssigned Matter[] @relation("MatterAssignee")
  uploadedDocuments Document[] @relation("DocumentUploader")
  tasksAssigned Task[] @relation("TaskAssignee")
  createdThreads AiChatThread[] @relation("ThreadCreator")
  auditEvents AuditEvent[]
}

model Client {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  firstName   String
  lastName    String
  dob         DateTime
  nationality String
  email       String
  phone       String
  notes       String?
  createdAt   DateTime @default(now())
  matters     Matter[]
  documents   Document[]
}

model Matter {
  id                 String   @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  clientId           String
  client             Client @relation(fields: [clientId], references: [id])
  title              String
  visaSubclass       String
  visaStream         String
  status             MatterStatus
  stage              MatterStage
  lodgementTargetDate DateTime?
  assignedToUserId   String
  assignedToUser     User @relation("MatterAssignee", fields: [assignedToUserId], references: [id])
  readinessScore     Int
  lastReviewedAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  documents          Document[]
  extractedFields    ExtractedField[]
  validationIssues   ValidationIssue[]
  checklistItems     ChecklistItem[]
  impacts            MatterImpact[]
  tasks              Task[]
  aiThreads          AiChatThread[]
}

model Document {
  id               String   @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  clientId         String
  client           Client @relation(fields: [clientId], references: [id])
  matterId         String
  matter           Matter @relation(fields: [matterId], references: [id])
  fileName         String
  storageKey       String
  mimeType         String
  category         String
  subcategory      String?
  uploadedByUserId String
  uploadedByUser   User @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  extractionStatus ExtractionStatus
  reviewStatus     ReviewStatus
  createdAt        DateTime @default(now())
  extractedFields  ExtractedField[]
}

model ExtractedField {
  id            String   @id @default(cuid())
  matterId      String
  matter        Matter @relation(fields: [matterId], references: [id])
  documentId    String
  document      Document @relation(fields: [documentId], references: [id])
  fieldKey      String
  fieldLabel    String
  fieldValue    String
  confidence    Float
  sourceSnippet String
  sourcePageRef String
  status        FieldStatus
  needsReview   Boolean
  createdAt     DateTime @default(now())
}

model ValidationIssue {
  id               String   @id @default(cuid())
  matterId         String
  matter           Matter @relation(fields: [matterId], references: [id])
  severity         IssueSeverity
  type             String
  title            String
  description      String
  relatedFieldKey  String?
  resolutionStatus ResolutionStatus
  createdAt        DateTime @default(now())
}

model ChecklistItem {
  id        String   @id @default(cuid())
  matterId  String
  matter    Matter @relation(fields: [matterId], references: [id])
  category  String
  label     String
  status    String
  required  Boolean
  notes     String?
}

model OfficialUpdate {
  id             String   @id @default(cuid())
  source         String
  sourceUrl      String
  title          String
  summary        String
  updateType     String
  effectiveDate  DateTime?
  publishedAt    DateTime
  rawContentHash String
  createdAt      DateTime @default(now())
  impacts        MatterImpact[]
}

model MatterImpact {
  id               String   @id @default(cuid())
  officialUpdateId String
  officialUpdate   OfficialUpdate @relation(fields: [officialUpdateId], references: [id])
  matterId         String
  matter           Matter @relation(fields: [matterId], references: [id])
  impactLevel      ImpactLevel
  reason           String
  status           ImpactStatus
  createdAt        DateTime @default(now())
}

model Task {
  id               String   @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
  matterId         String
  matter           Matter @relation(fields: [matterId], references: [id])
  assignedToUserId String
  assignedToUser   User @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  title            String
  description      String
  dueDate          DateTime
  status           TaskStatus
  priority         TaskPriority
}

model AiChatThread {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  matterId        String?
  matter          Matter? @relation(fields: [matterId], references: [id])
  title           String
  createdByUserId String
  createdByUser   User @relation("ThreadCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  messages        AiChatMessage[]
}

model AiChatMessage {
  id            String   @id @default(cuid())
  threadId      String
  thread        AiChatThread @relation(fields: [threadId], references: [id])
  role          ChatRole
  content       String
  citationsJson Json?
  createdAt     DateTime @default(now())
}

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User @relation(fields: [userId], references: [id])
  entityType  String
  entityId    String
  action      String
  metadataJson Json?
  createdAt   DateTime @default(now())
}
