generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspacePlan {
  STARTER
  GROWTH
  PRO
}

enum UserRole {
  ADMIN
  AGENT
  REVIEWER
  OPS
}

enum MatterStatus {
  IN_PROGRESS
  AWAITING_DOCS
  READY_FOR_REVIEW
  DRAFT
}

enum MatterStage {
  INTAKE
  EVIDENCE
  FIELD_REVIEW
  VALIDATION
  SUBMISSION_PREP
}

enum ExtractionStatus {
  QUEUED
  EXTRACTED
  NEEDS_REVIEW
}

enum ReviewStatus {
  PENDING
  VERIFIED
  FLAGGED
}

enum FieldStatus {
  HIGH_CONFIDENCE
  SUPPORTED
  NEEDS_REVIEW
  CONFLICTING
  MISSING
  VERIFIED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ResolutionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImpactStatus {
  NEW
  REVIEWING
  ACTIONED
  DISMISSED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
}

enum TemplateValueType {
  TEXT
  DATE
  NUMBER
  BOOLEAN
  CURRENCY
  SELECT
  MULTI_SELECT
}

enum DraftStatus {
  DRAFTING
  READY_FOR_AGENT_REVIEW
  AGENT_REVIEWED
  READY_FOR_CLIENT_REVIEW
  SENT_TO_CLIENT
  CLIENT_CONFIRMED
  RETURNED_TO_AGENT
  NEEDS_WORK
}

enum DraftFieldStatus {
  HIGH_CONFIDENCE
  SUPPORTED
  NEEDS_REVIEW
  CONFLICTING
  MISSING
  VERIFIED
}

enum ReviewRequestStatus {
  REVIEW_REQUESTED
  SENT_TO_CLIENT
  VIEWED_BY_CLIENT
  SIGNED_CONFIRMED
  RETURNED_TO_AGENT
  REQUIRES_FOLLOW_UP
}

model Workspace {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  plan                  WorkspacePlan
  createdAt             DateTime               @default(now())
  users                 User[]
  clients               Client[]
  matters               Matter[]
  documents             Document[]
  tasks                 Task[]
  aiThreads             AiChatThread[]
  auditEvents           AuditEvent[]
  visaSubclassTemplates VisaSubclassTemplate[]
  officialSources       OfficialSource[]
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  hashedPassword    String?
  role              UserRole
  workspaceId       String
  workspace         Workspace      @relation(fields: [workspaceId], references: [id])
  mattersAssigned   Matter[]       @relation("MatterAssignee")
  uploadedDocuments Document[]     @relation("DocumentUploader")
  tasksAssigned     Task[]         @relation("TaskAssignee")
  createdThreads    AiChatThread[] @relation("ThreadCreator")
  auditEvents       AuditEvent[]
}

model Client {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])
  firstName   String
  lastName    String
  dob         DateTime
  nationality String
  email       String
  phone       String
  notes       String?
  createdAt   DateTime   @default(now())
  matters     Matter[]
  documents   Document[]
}

model Matter {
  id                  String                   @id @default(cuid())
  workspaceId         String
  workspace           Workspace                @relation(fields: [workspaceId], references: [id])
  clientId            String
  client              Client                   @relation(fields: [clientId], references: [id])
  title               String
  visaSubclass        String
  visaStream          String
  status              MatterStatus
  stage               MatterStage
  lodgementTargetDate DateTime?
  assignedToUserId    String
  assignedToUser      User                     @relation("MatterAssignee", fields: [assignedToUserId], references: [id])
  readinessScore      Int
  lastReviewedAt      DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  documents           Document[]
  extractedFields     ExtractedField[]
  validationIssues    ValidationIssue[]
  checklistItems      ChecklistItem[]
  impacts             MatterImpact[]
  tasks               Task[]
  aiThreads           AiChatThread[]
  applicationDrafts   MatterApplicationDraft[]
  reviewRequests      MatterReviewRequest[]
}

model Document {
  id                 String                         @id @default(cuid())
  workspaceId        String
  workspace          Workspace                      @relation(fields: [workspaceId], references: [id])
  clientId           String
  client             Client                         @relation(fields: [clientId], references: [id])
  matterId           String
  matter             Matter                         @relation(fields: [matterId], references: [id])
  fileName           String
  storageKey         String
  mimeType           String
  category           String
  subcategory        String?
  uploadedByUserId   String
  uploadedByUser     User                           @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  extractionStatus   ExtractionStatus
  reviewStatus       ReviewStatus
  createdAt          DateTime                       @default(now())
  extractedFields    ExtractedField[]
  draftEvidenceLinks MatterDraftFieldEvidenceLink[]
  extractionResults  DocumentExtractionResult[]
}

model ExtractedField {
  id            String      @id @default(cuid())
  matterId      String
  matter        Matter      @relation(fields: [matterId], references: [id])
  documentId    String
  document      Document    @relation(fields: [documentId], references: [id])
  fieldKey      String
  fieldLabel    String
  fieldValue    String
  confidence    Float
  sourceSnippet String
  sourcePageRef String
  status        FieldStatus
  needsReview   Boolean
  createdAt     DateTime    @default(now())
}

model ValidationIssue {
  id               String           @id @default(cuid())
  matterId         String
  matter           Matter           @relation(fields: [matterId], references: [id])
  severity         IssueSeverity
  type             String
  title            String
  description      String
  relatedFieldKey  String?
  resolutionStatus ResolutionStatus
  createdAt        DateTime         @default(now())
}

model ChecklistItem {
  id       String  @id @default(cuid())
  matterId String
  matter   Matter  @relation(fields: [matterId], references: [id])
  category String
  label    String
  status   String
  required Boolean
  notes    String?
}

model VisaSubclassTemplate {
  id             String                      @id @default(cuid())
  workspaceId    String?
  workspace      Workspace?                  @relation(fields: [workspaceId], references: [id])
  subclassCode   String
  stream         String?
  name           String
  description    String
  version        String
  active         Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  sections       VisaTemplateSection[]
  fields         VisaTemplateField[]
  requirements   VisaTemplateRequirement[]
  checklistItems VisaTemplateChecklistItem[]
  drafts         MatterApplicationDraft[]

  @@unique([workspaceId, subclassCode, stream, version])
  @@index([subclassCode, stream, active])
}

model VisaTemplateSection {
  id          String               @id @default(cuid())
  templateId  String
  template    VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key         String
  title       String
  description String?
  sortOrder   Int
  fields      VisaTemplateField[]

  @@unique([templateId, key])
}

model VisaTemplateField {
  id                          String               @id @default(cuid())
  templateId                  String
  template                    VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionId                   String
  section                     VisaTemplateSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  fieldKey                    String
  label                       String
  helpText                    String?
  valueType                   TemplateValueType
  required                    Boolean              @default(false)
  supportedDocumentCategories String[]
  validationRules             Json?
  sortOrder                   Int
  draftFields                 MatterDraftField[]

  @@unique([templateId, fieldKey])
}

model VisaTemplateRequirement {
  id           String               @id @default(cuid())
  templateId   String
  template     VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category     String
  label        String
  description  String
  required     Boolean              @default(true)
  ruleKey      String
  metadataJson Json?

  @@unique([templateId, ruleKey])
}

model VisaTemplateChecklistItem {
  id           String               @id @default(cuid())
  templateId   String
  template     VisaSubclassTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category     String
  label        String
  required     Boolean              @default(true)
  sortOrder    Int
  metadataJson Json?
}

model MatterApplicationDraft {
  id             String                @id @default(cuid())
  matterId       String
  matter         Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  templateId     String
  template       VisaSubclassTemplate  @relation(fields: [templateId], references: [id])
  status         DraftStatus           @default(DRAFTING)
  readinessScore Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  fields         MatterDraftField[]
  reviewRequests MatterReviewRequest[]

  @@unique([matterId, templateId])
}

model MatterDraftField {
  id              String                         @id @default(cuid())
  draftId         String
  draft           MatterApplicationDraft         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  templateFieldId String
  templateField   VisaTemplateField              @relation(fields: [templateFieldId], references: [id])
  value           String?
  confidence      Float?
  sourceSnippet   String?
  sourcePageRef   String?
  status          DraftFieldStatus               @default(MISSING)
  reviewedAt      DateTime?
  verifiedAt      DateTime?
  manualOverride  String?
  notes           String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  evidenceLinks   MatterDraftFieldEvidenceLink[]

  @@unique([draftId, templateFieldId])
}

model MatterDraftFieldEvidenceLink {
  id            String           @id @default(cuid())
  draftFieldId  String
  draftField    MatterDraftField @relation(fields: [draftFieldId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sourceSnippet String?
  sourcePageRef String?
  confidence    Float?
  createdAt     DateTime         @default(now())
}

model DocumentExtractionResult {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  provider      String
  model         String?
  extractedJson Json
  createdAt     DateTime @default(now())
}

model MatterReviewRequest {
  id             String                 @id @default(cuid())
  matterId       String
  matter         Matter                 @relation(fields: [matterId], references: [id], onDelete: Cascade)
  draftId        String
  draft          MatterApplicationDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  status         ReviewRequestStatus    @default(REVIEW_REQUESTED)
  recipientEmail String?
  recipientName  String?
  message        String?
  sentAt         DateTime?
  viewedAt       DateTime?
  confirmedAt    DateTime?
  returnedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model OfficialUpdate {
  id             String         @id @default(cuid())
  officialSourceId String?
  officialSource   OfficialSource? @relation(fields: [officialSourceId], references: [id])
  source         String
  sourceUrl      String
  title          String
  summary        String
  updateType     String
  effectiveDate  DateTime?
  publishedAt    DateTime
  rawContentHash String
  sourceMetadata Json?
  ingestedAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())
  impacts        MatterImpact[]

  @@unique([sourceUrl, rawContentHash])
  @@index([publishedAt])
  @@index([updateType])
}

model OfficialSource {
  id          String           @id @default(cuid())
  workspaceId String?
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id])
  name        String
  sourceType  String
  url         String
  active      Boolean          @default(true)
  metadataJson Json?
  lastFetchedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  updates     OfficialUpdate[]

  @@unique([url])
  @@index([active, sourceType])
}

model MatterImpact {
  id               String         @id @default(cuid())
  officialUpdateId String
  officialUpdate   OfficialUpdate @relation(fields: [officialUpdateId], references: [id])
  matterId         String
  matter           Matter         @relation(fields: [matterId], references: [id])
  impactLevel      ImpactLevel
  reason           String
  actionRequired   String?
  status           ImpactStatus
  createdAt        DateTime       @default(now())

  @@unique([officialUpdateId, matterId])
}

model Task {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id])
  matterId         String
  matter           Matter       @relation(fields: [matterId], references: [id])
  assignedToUserId String
  assignedToUser   User         @relation("TaskAssignee", fields: [assignedToUserId], references: [id])
  title            String
  description      String
  dueDate          DateTime
  status           TaskStatus
  priority         TaskPriority
}

model AiChatThread {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id])
  matterId        String?
  matter          Matter?         @relation(fields: [matterId], references: [id])
  title           String
  createdByUserId String
  createdByUser   User            @relation("ThreadCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime        @default(now())
  messages        AiChatMessage[]
}

model AiChatMessage {
  id            String       @id @default(cuid())
  threadId      String
  thread        AiChatThread @relation(fields: [threadId], references: [id])
  role          ChatRole
  content       String
  citationsJson Json?
  createdAt     DateTime     @default(now())
}

model AuditEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  entityType   String
  entityId     String
  action       String
  metadataJson Json?
  createdAt    DateTime  @default(now())
}
